<?xml version="1.0" encoding="utf-8"?>
<!--
  UOH Meetings API – IIS Configuration (ASP.NET Core Module v2)
  This file configures IIS as a reverse proxy to Kestrel.
  WebSockets must be enabled for SignalR hubs.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- ASP.NET Core Module v2: out-of-process hosting via Kestrel -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <aspNetCore processPath="dotnet"
                  arguments=".\UohMeetings.Api.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="OutOfProcess"
                  forwardWindowsAuthToken="false">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="ASPNETCORE_FORWARDEDHEADERS_ENABLED" value="true" />
        </environmentVariables>
      </aspNetCore>

      <!-- Enable WebSockets for SignalR hubs -->
      <webSocket enabled="true" />

      <!-- Security headers -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="Referrer-Policy" value="no-referrer" />
          <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
        </customHeaders>
      </httpProtocol>

      <!-- Request limits (100MB for file uploads) -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>

      <!-- Compression -->
      <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    </system.webServer>
  </location>
</configuration>
